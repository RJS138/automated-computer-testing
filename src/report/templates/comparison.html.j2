<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Before/After Comparison — {{ job.customer_name }}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      font-size: 13px;
      color: #1a1a1a;
      background: #f5f5f5;
      padding: 24px;
    }
    .page { max-width: 960px; margin: 0 auto; background: #fff; border-radius: 8px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.10); overflow: hidden; }

    .header {
      background: #1e3a5f;
      color: #fff;
      padding: 24px 32px;
    }
    .header h1 { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
    .header .meta { font-size: 12px; opacity: 0.8; line-height: 1.8; }

    /* Summary pills */
    .diff-summary {
      display: flex;
      gap: 16px;
      padding: 16px 32px;
      border-bottom: 1px solid #e0e0e0;
      background: #fafafa;
      align-items: center;
    }
    .pill {
      padding: 6px 16px;
      border-radius: 20px;
      font-weight: 700;
      font-size: 13px;
    }
    .pill-improved  { background: #c8e6c9; color: #2e7d32; }
    .pill-worsened  { background: #ffcdd2; color: #c62828; }
    .pill-unchanged { background: #eeeeee; color: #555; }

    /* Job info */
    .job-info {
      padding: 16px 32px;
      border-bottom: 1px solid #e0e0e0;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
    }
    .job-info .field label { font-size: 11px; text-transform: uppercase; color: #888; display: block; }
    .job-info .field span  { font-size: 13px; font-weight: 600; }

    /* Comparison table */
    .comparison-section { padding: 24px 32px; }
    .comparison-section h2 { font-size: 16px; font-weight: 700; margin-bottom: 16px; color: #1e3a5f; }

    .comp-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .comp-table thead th {
      padding: 10px 12px;
      background: #1e3a5f;
      color: #fff;
      text-align: left;
      font-weight: 600;
    }
    .comp-table thead th.col-before { background: #2a5298; }
    .comp-table thead th.col-after  { background: #1b4a2a; }

    .comp-table tbody tr { border-bottom: 1px solid #e8e8e8; }
    .comp-table tbody tr:nth-child(even) { background: #f9f9f9; }
    .comp-table td { padding: 10px 12px; vertical-align: top; }

    .comp-table td.test-name { font-weight: 600; }

    /* Change indicators */
    .change-improved  { background: #e8f5e9 !important; }
    .change-worsened  { background: #ffebee !important; }

    .status-badge {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      padding: 2px 8px;
      border-radius: 10px;
      margin-bottom: 3px;
    }
    .status-badge.pass    { background: #c8e6c9; color: #2e7d32; }
    .status-badge.warn    { background: #fff9c4; color: #f57f17; }
    .status-badge.fail    { background: #ffcdd2; color: #c62828; }
    .status-badge.skip    { background: #eeeeee; color: #757575; }
    .status-badge.error   { background: #ffcdd2; color: #c62828; }

    .arrow-col { text-align: center; font-size: 18px; vertical-align: middle; }
    .arrow-improved { color: #2e7d32; }
    .arrow-worsened { color: #c62828; }
    .arrow-unchanged { color: #bbb; }
    .arrow-changed { color: #f57f17; }

    .footer {
      padding: 16px 32px;
      background: #fafafa;
      border-top: 1px solid #e0e0e0;
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: #888;
    }

    @media print {
      body { background: #fff; padding: 0; }
      .page { box-shadow: none; border-radius: 0; }
    }
  </style>
</head>
<body>
<div class="page">

  <!-- Header -->
  <div class="header">
    <div style="display:flex;align-items:center;gap:16px;">
      {% if branding_logo %}
      <img src="{{ branding_logo }}" alt="Logo" style="height:48px;border-radius:4px;flex-shrink:0;">
      {% endif %}
      <div>
        <h1>{% if branding_name %}{{ branding_name }} — {% endif %}Before / After Comparison</h1>
        <div class="meta">
          Customer: {{ job.customer_name }} &nbsp;|&nbsp;
          Device: {{ job.device_description }} &nbsp;|&nbsp;
          Job #{{ job.job_number }}
        </div>
      </div>
    </div>
  </div>

  <!-- Summary -->
  <div class="diff-summary">
    <span style="font-weight:600;color:#555;">Changes:</span>
    <span class="pill pill-improved">{{ improved }} Improved</span>
    <span class="pill pill-worsened">{{ worsened }} Worsened</span>
    <span class="pill pill-unchanged">{{ unchanged }} Unchanged</span>
  </div>

  <!-- Job info -->
  <div class="job-info">
    <div class="field"><label>Customer</label><span>{{ job.customer_name }}</span></div>
    <div class="field"><label>Device</label><span>{{ job.device_description }}</span></div>
    <div class="field"><label>Job #</label><span>{{ job.job_number }}</span></div>
  </div>

  <!-- Comparison table -->
  <div class="comparison-section">
    <h2>Test-by-Test Comparison</h2>
    <table class="comp-table">
      <thead>
        <tr>
          <th style="width:20%">Test</th>
          <th class="col-before" style="width:36%">Before</th>
          <th style="width:8%; text-align:center;">→</th>
          <th class="col-after"  style="width:36%">After</th>
        </tr>
      </thead>
      <tbody>
        {% for row in rows %}
        <tr class="{% if row.change == 'improved' %}change-improved{% elif row.change == 'worsened' %}change-worsened{% endif %}">
          <td class="test-name">{{ row.display_name }}</td>
          <td>
            <span class="status-badge {{ row.before_status }}">{{ row.before_status | upper }}</span><br>
            <small>{{ row.before_summary }}</small>
          </td>
          <td class="arrow-col">
            {% if row.change == 'improved' %}
              <span class="arrow-improved">↑</span>
            {% elif row.change == 'worsened' %}
              <span class="arrow-worsened">↓</span>
            {% elif row.change == 'changed' %}
              <span class="arrow-changed">⇄</span>
            {% else %}
              <span class="arrow-unchanged">—</span>
            {% endif %}
          </td>
          <td>
            <span class="status-badge {{ row.after_status }}">{{ row.after_status | upper }}</span><br>
            <small>{{ row.after_summary }}</small>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <!-- Footer -->
  <div class="footer">
    <span>Touchstone — Before/After Comparison Report{% if branding_name %} &nbsp;·&nbsp; Prepared by {{ branding_name }}{% endif %}</span>
    <span>{{ job.customer_name }} | {{ job.job_number }}</span>
  </div>

</div>

<!-- Embedded JSON for PDF generation -->
<script id="comparison-data" type="application/json">
{{ comparison_json | safe }}
</script>
</body>
</html>
